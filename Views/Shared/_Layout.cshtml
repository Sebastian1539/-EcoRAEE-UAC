<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoRAEE UAC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background:#1B5E20;">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-recycle"></i> EcoRAEE UAC
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Inicio
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Campañas" asp-action="Index">
                            <i class="bi bi-calendar-event"></i> Campañas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Participantes" asp-action="Index">
                            <i class="bi bi-people"></i> Participantes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="RecoleccionRaee" asp-action="Index">
                            <i class="bi bi-trash2"></i> Recolección RAEE
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="MaterialEducativo" asp-action="Index">
                            <i class="bi bi-book"></i> Material
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Reportes" asp-action="Index">
                            <i class="bi bi-bar-chart"></i> Reportes
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle"></i> @TempData["Exito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-5">
        <small>EcoRAEE UAC &copy; 2026 - Universidad Andina del Cusco | RSU</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
