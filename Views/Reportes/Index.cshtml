@model EcoRAEE_UAC.Models.ViewModels.ReporteViewModel
@{
    ViewData["Title"] = "Reportes e Indicadores";
}

<h2><i class="bi bi-bar-chart-fill text-success"></i> Dashboard de Impacto RSU</h2>
<hr />

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white" style="background:#1B5E20;">
            <div class="card-body text-center">
                <h1>@Model.TotalCampañas</h1>
                <p>Total Campañas</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h1>@Model.TotalParticipantes</h1>
                <p>Total Participantes</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body text-center">
                <h1>@Model.TotalRaeeKg.ToString("F1") Kg</h1>
                <p>RAEE Recolectados</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-secondary">
            <div class="card-body text-center">
                <h1>@Model.CampañasFinalizadas</h1>
                <p>Campañas Finalizadas</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <h5>Participantes por Tipo</h5>
        <table class="table table-bordered">
            <thead class="table-success">
                <tr><th>Tipo</th><th>Total</th></tr>
            </thead>
            <tbody>
                @foreach (var kv in Model.ParticipantesPorTipo)
                {
                    <tr><td>@kv.Key</td><td>@kv.Value</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-6">
        <h5>RAEE por Tipo de Residuo (Kg)</h5>
        <table class="table table-bordered">
            <thead class="table-info">
                <tr><th>Tipo Residuo</th><th>Kg</th></tr>
            </thead>
            <tbody>
                @foreach (var kv in Model.RaeePorTipo)
                {
                    <tr><td>@kv.Key</td><td>@kv.Value.ToString("F2")</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
