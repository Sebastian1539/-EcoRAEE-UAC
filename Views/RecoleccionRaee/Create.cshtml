@model EcoRAEE_UAC.Models.RecoleccionRaee
@{
    ViewData["Title"] = "Nueva Recolección RAEE";
}

<h2><i class="bi bi-plus-circle text-success"></i> Nueva Recolección RAEE</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="TipoResiduo" class="form-label"></label>
                <input asp-for="TipoResiduo" class="form-control" />
                <span asp-validation-for="TipoResiduo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CantidadKg" class="form-label"></label>
                <input asp-for="CantidadKg" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="CantidadKg" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LugarRecoleccion" class="form-label"></label>
                <input asp-for="LugarRecoleccion" class="form-control" />
                <span asp-validation-for="LugarRecoleccion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Fecha" class="form-label"></label>
                <input asp-for="Fecha" class="form-control" type="date" />
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CampañaId" class="form-label"></label>
                <select asp-for="CampañaId" class="form-select" asp-items='new SelectList(ViewBag.Campañas, "Id", "Nombre")'>
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="CampañaId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Observaciones" class="form-label"></label>
                <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Guardar</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
