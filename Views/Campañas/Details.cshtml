@model EcoRAEE_UAC.Models.Campaña
@{
    ViewData["Title"] = "Detalles de Campaña";
}

<h2><i class="bi bi-eye text-success"></i> @Html.DisplayFor(m => m.Nombre)</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">Fecha</dt>
            <dd class="col-sm-9">@Model.Fecha.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Lugar</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Lugar)</dd>

            <dt class="col-sm-3">Responsable</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Responsable)</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">
                <span class="badge @(Model.Estado == EstadoCampaña.Finalizada ? "bg-secondary" :
                                     Model.Estado == EstadoCampaña.EnCurso ? "bg-success" : "bg-warning")">
                    @Model.Estado
                </span>
            </dd>

            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Html.DisplayFor(m => m.Descripcion)</dd>
        </dl>

        <div class="mb-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Editar
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <i class="bi bi-people"></i> Participantes (@Model.Participantes.Count)
            </div>
            <div class="card-body">
                @if (Model.Participantes.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var p in Model.Participantes)
                        {
                            <li class="list-group-item">@p.Nombres @p.Apellidos - @p.TipoParticipante</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">Sin participantes registrados.</p>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <i class="bi bi-trash2"></i> RAEE Recolectado (@Model.RecoleccionesRaee.Sum(r => r.CantidadKg) Kg)
            </div>
            <div class="card-body">
                @if (Model.RecoleccionesRaee.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var r in Model.RecoleccionesRaee)
                        {
                            <li class="list-group-item">@r.TipoResiduo - @r.CantidadKg Kg</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">Sin recolecciones registradas.</p>
                }
            </div>
        </div>
    </div>
</div>
