@model IEnumerable<EcoRAEE_UAC.Models.Campaña>
@{
    ViewData["Title"] = "Campañas Ambientales";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-event text-success"></i> Campañas Ambientales</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nueva Campaña
    </a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header text-white" style="background:#2E7D32;">
                    <strong>@Html.DisplayFor(m => item.Nombre)</strong>
                </div>
                <div class="card-body">
                    <p><i class="bi bi-calendar3"></i> @item.Fecha.ToString("dd/MM/yyyy")</p>
                    <p><i class="bi bi-geo-alt"></i> @item.Lugar</p>
                    <p><i class="bi bi-person"></i> @item.Responsable</p>
                    <span class="badge @(item.Estado == EstadoCampaña.Finalizada ? "bg-secondary" :
                                         item.Estado == EstadoCampaña.EnCurso ? "bg-success" : "bg-warning")">
                        @item.Estado
                    </span>
                </div>
                <div class="card-footer bg-white d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-eye"></i> Ver
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i> Eliminar
                    </a>
                </div>
            </div>
        </div>
    }
</div>
