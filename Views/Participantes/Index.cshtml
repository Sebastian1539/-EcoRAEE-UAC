@model IEnumerable<EcoRAEE_UAC.Models.Participante>
@{
    ViewData["Title"] = "Participantes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people text-success"></i> Participantes</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Participante
    </a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-success">
        <tr>
            <th>Nombres</th>
            <th>Apellidos</th>
            <th>Tipo</th>
            <th>DNI</th>
            <th>Email</th>
            <th>Campaña</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(m => item.Nombres)</td>
                <td>@Html.DisplayFor(m => item.Apellidos)</td>
                <td><span class="badge bg-success">@item.TipoParticipante</span></td>
                <td>@Html.DisplayFor(m => item.DNI)</td>
                <td>@Html.DisplayFor(m => item.Email)</td>
                <td>@item.Campaña?.Nombre</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
