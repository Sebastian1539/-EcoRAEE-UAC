@model EcoRAEE_UAC.Models.Participante
@{
    ViewData["Title"] = "Nuevo Participante";
}

<h2><i class="bi bi-plus-circle text-success"></i> Nuevo Participante</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombres" class="form-label"></label>
                <input asp-for="Nombres" class="form-control" />
                <span asp-validation-for="Nombres" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Apellidos" class="form-label"></label>
                <input asp-for="Apellidos" class="form-control" />
                <span asp-validation-for="Apellidos" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TipoParticipante" class="form-label"></label>
                <select asp-for="TipoParticipante" asp-items="Html.GetEnumSelectList<TipoParticipante>()" class="form-select"></select>
                <span asp-validation-for="TipoParticipante" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DNI" class="form-label"></label>
                <input asp-for="DNI" class="form-control" />
                <span asp-validation-for="DNI" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Telefono" class="form-label"></label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CampañaId" class="form-label"></label>
                <select asp-for="CampañaId" class="form-select" asp-items='new SelectList(ViewBag.Campañas, "Id", "Nombre")'>
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="CampañaId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save"></i> Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
