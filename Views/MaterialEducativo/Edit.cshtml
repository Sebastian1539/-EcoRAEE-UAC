@model EcoRAEE_UAC.Models.MaterialEducativo
@{
    ViewData["Title"] = "Editar Material Educativo";
}

<h2><i class="bi bi-pencil text-warning"></i> Editar Material Educativo</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Titulo" class="form-label"></label>
                <input asp-for="Titulo" class="form-control" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tipo" class="form-label"></label>
                <select asp-for="Tipo" asp-items="Html.GetEnumSelectList<TipoMaterial>()" class="form-select"></select>
                <span asp-validation-for="Tipo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="UrlArchivo" class="form-label"></label>
                <input asp-for="UrlArchivo" class="form-control" />
                <span asp-validation-for="UrlArchivo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FechaPublicacion" class="form-label"></label>
                <input asp-for="FechaPublicacion" class="form-control" type="date" />
                <span asp-validation-for="FechaPublicacion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CampañaId" class="form-label"></label>
                <select asp-for="CampañaId" class="form-select" asp-items='new SelectList(ViewBag.Campañas, "Id", "Nombre")'>
                    <option value="">-- Sin campaña --</option>
                </select>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> Actualizar</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
