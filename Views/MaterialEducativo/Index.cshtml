@model IEnumerable<EcoRAEE_UAC.Models.MaterialEducativo>
@{
    ViewData["Title"] = "Material Educativo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-book text-success"></i> Material Educativo</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Material
    </a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body">
                    <h5 class="card-title">@item.Titulo</h5>
                    <span class="badge bg-info">@item.Tipo</span>
                    <p class="card-text mt-2">@item.Descripcion</p>
                    <p class="text-muted small">
                        <i class="bi bi-calendar3"></i> @item.FechaPublicacion.ToString("dd/MM/yyyy")
                        @if (item.Campaña != null)
                        {
                            <br /><i class="bi bi-calendar-event"></i> @item.Campaña.Nombre
                        }
                    </p>
                    @if (!string.IsNullOrEmpty(item.UrlArchivo))
                    {
                        <a href="@item.UrlArchivo" target="_blank" class="btn btn-sm btn-outline-success">
                            <i class="bi bi-eye"></i> Ver
                        </a>
                    }
                </div>
                <div class="card-footer bg-white d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>
